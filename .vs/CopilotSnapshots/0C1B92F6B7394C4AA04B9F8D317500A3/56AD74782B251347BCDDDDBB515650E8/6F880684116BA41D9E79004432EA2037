using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;
using static System.Net.Mime.MediaTypeNames;

namespace gestor_empresa
{
    public partial class FormEmpleado : Form
    {
        GestorEmpleado gestor = new GestorEmpleado();
        private Empleado usuario;
        private Contrato contrato;
        private Empresa empresa;
        
        // Método que le pasa al form datos del empleado, del contrato y de la empresa
        public FormEmpleado(Empleado empl, Contrato cont, Empresa empres)
        {
            InitializeComponent();
            usuario = empl;
            contrato = cont;
            empresa = empres;
        }
        public void CargarDatos()
        {
            // DGVs
            DataTable tablaNominas = gestor.ObtenerNominasPorEmpleado(usuario.Id);
            dgvNominas.DataSource = tablaNominas;
            DataTable tablaBajas = gestor.ObtenerBajasPorEmpleado(usuario.Id);
            dgvBajas.DataSource = tablaBajas;

            // Labels centro
            lblEmpresa.Text = "Empresa: " + empresa.Nombre;
            lblEstado.Text = contrato.Estado ? "Estado: Activo" : "Estado: Inactivo";
            lblTipoContrato.Text = "Tipo: " + contrato.TipoContrato;
            lblSalario.Text = "Salario anual: " + contrato.Bruto;
            lblInfoEmpMedio.Text = "Portal del empleado: " + usuario.Nombre + " " + usuario.Apellidos;
            //Labels izq + foto
            lblInfoEmpIzq.Text = usuario.Nombre + " " + usuario.Apellidos + "\n" + usuario.Nif;
        }

        private void FormEmpleado_Load(object sender, EventArgs e)
        {
            CargarDatos();
        }

        private void btnLogOff_Click(object sender, EventArgs e)
        {
            DialogResult respuesta = MessageBox.Show("¿Seguro que quieres cerrar la sesión?", "Confirmación",
                MessageBoxButtons.YesNo);

            if (respuesta == DialogResult.Yes)
            {
                System.Windows.Forms.Application.Restart();
            }
        }

        private void timer1_Tick(object sender, EventArgs e)
        {
            lblHora.Text = DateTime.Now.ToString("HH:mm");
        }
        public void btnFichar_Click(object sender, EventArgs e)
        {
            int empleadoId = usuario.Id;
            DateTime hoy = DateTime.Today;
            string fechaHoy = hoy.ToString("yyyy-MM-dd");

            // Buscar fichaje abierto del empleado para hoy
            string sqlBuscar = $"SELECT * FROM jornada WHERE id_empleado = {empleadoId} AND hora_salida IS NULL AND DATE(hora_entrada) = '{fechaHoy}'";
            DataTable resultado = Database.Consulta(sqlBuscar);

            if (resultado != null && resultado.Rows.Count == 0)
            {
                // Registrar entrada
                string horaActual = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
                string sqlInsertar = $"INSERT INTO jornada (id_empleado, fecha, hora_entrada) VALUES ({empleadoId}, '{fechaHoy}', '{horaActual}')";
                Database.Modificacion(sqlInsertar);

                if (Database.NumRegModif > 0)
                {
                    MessageBox.Show("Entrada registrada.");
                }
                else
                {
                    MessageBox.Show("Error al registrar la entrada: " + Database.Error);
                }
            }
            else if (resultado != null && resultado.Rows.Count > 0)
            {
                // Registrar salida
                string horaActual = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
                int jornadaId = Convert.ToInt32(resultado.Rows[0]["id"]);
                string sqlActualizar = $"UPDATE jornada SET hora_salida = '{horaActual}' WHERE id = {jornadaId}";
                Database.Modificacion(sqlActualizar);

                if (Database.NumRegModif > 0)
                {
                    MessageBox.Show("Salida registrada.");
                }
                else
                {
                    MessageBox.Show("Error al registrar la salida: " + Database.Error);
                }
            }
            else
            {
                MessageBox.Show("Error en la base de datos: " + Database.Error);
            }
        }
    }
}
